# LLM Configuration
# Option 1: Local model via Ollama (default, no API key needed)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b

# Option 2: OpenAI-compatible API
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Embedding model
# Accepts HuggingFace Hub ID (auto-downloaded on first run) or local path.
# Examples:
#   EMBEDDING_MODEL=BAAI/bge-small-en-v1.5          (HuggingFace, default)
#   EMBEDDING_MODEL=/app/models/bge-small-en-v1.5   (pre-downloaded local path)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Reranker model
# Same format as embedding: HuggingFace Hub ID or local path.
# Examples:
#   RERANKER_MODEL=BAAI/bge-reranker-base            (HuggingFace, default)
#   RERANKER_MODEL=/app/models/bge-reranker-base      (pre-downloaded local path)
RERANKER_MODEL=BAAI/bge-reranker-base

# Service ports
GO_BACKEND_PORT=8080
PYTHON_SERVICE_PORT=8000
FRONTEND_PORT=3000
